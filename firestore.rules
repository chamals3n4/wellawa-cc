rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Shared students collection for all signed-in teachers
    match /students/{studentId} {
      allow read, write: if signedIn();
    }

    // Shared marks collection (doc id == studentId)
    match /marks/{studentId} {
      allow read, write: if signedIn();
    }

    // Shared general settings
    match /general/{docId} {
      allow read, write: if signedIn();
    }
  }
}
